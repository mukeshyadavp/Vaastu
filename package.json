{
  "name": "vaastu-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "nodemon --watch backend --ext py --exec \"python backend/app.py\"",
    "dev:full": "concurrently -k -n REACT,FLASK -c green,blue \"npm run dev\" \"npm run dev:backend\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "python backend/app.py",
    "prod": "npm run build && python backend/app.py"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.3",
    "leaflet-geosearch": "^4.4.0",
    "lucide-react": "^1.8.0",
    "path": "^0.12.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "react-leaflet": "^4.1.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/react": "18.2.66",
    "@types/react-dom": "18.2.22",
    "@vitejs/plugin-react": "4.2.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14",
    "typescript": "5.4.5",
    "vite": "5.2.0"
  }
}
